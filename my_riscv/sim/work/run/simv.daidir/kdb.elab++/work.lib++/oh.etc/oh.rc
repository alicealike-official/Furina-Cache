@elabcom rc file Version 1.0
[oh]
invokeDir = /mnt/hgfs/Project/eva-riscv/my_riscv/sim
hostCommand = -lib /mnt/hgfs/Project/eva-riscv/my_riscv/sim/work/run/simv.daidir/work -saveLevel -elab /mnt/hgfs/Project/eva-riscv/my_riscv/sim/work/run/simv.daidir/kdb -simflow -simdir /mnt/hgfs/Project/eva-riscv/my_riscv/sim/work/run/simv.daidir/kdb_libs -top tb_top -\
Lf work +disable_message+C00380+C00381 +disable_message+C00388+C00389 -SNPS_ELABCOM -saveElab
simType = VCS
